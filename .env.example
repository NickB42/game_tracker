# Local PostgreSQL container settings
POSTGRES_DB=dreierspoil_tracker
POSTGRES_USER=dreierspoil_app
POSTGRES_PASSWORD=dreierspoil_dev_password
POSTGRES_PORT=5432

# Prisma / application database connection
DATABASE_URL=postgresql://dreierspoil_app:dreierspoil_dev_password@localhost:5432/dreierspoil_tracker?schema=public
# Use unpooled/direct connection for Prisma migrations in deployed environments.
# Locally, this can match DATABASE_URL.
DIRECT_DATABASE_URL=postgresql://dreierspoil_app:dreierspoil_dev_password@localhost:5432/dreierspoil_tracker?schema=public

# Better Auth
# Canonical app URL (production URL in Vercel production, localhost in local dev)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace_with_a_secure_32_plus_character_secret
# Optional comma-separated list of additional trusted origins.
# Example: https://staging.example.com,https://admin.example.com
BETTER_AUTH_TRUSTED_ORIGINS=
# Optional comma-separated list of additional allowed hosts for dynamic Better Auth baseURL resolution.
# Example: app.example.com,preview-*.example.com
BETTER_AUTH_ALLOWED_HOSTS=
# Set true if you want wildcard preview host support on Vercel (*.vercel.app).
# Keep false unless you explicitly want that behavior.
BETTER_AUTH_ENABLE_VERCEL_PREVIEW=false

# Vercel runtime metadata (set automatically by Vercel in hosted environments)
# VERCEL_ENV=preview
# VERCEL_URL=your-preview-url.vercel.app
# VERCEL_BRANCH_URL=your-branch-url.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=your-production-url.vercel.app

# Initial admin seed user
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_first_login
ADMIN_NAME=Initial Admin
ADMIN_MUST_CHANGE_PASSWORD=true

# Optional dedicated E2E seed users (recommended for Playwright smoke tests)
E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=change_me_e2e_admin
E2E_ADMIN_NAME=E2E Admin
E2E_ADMIN_MUST_CHANGE_PASSWORD=false

E2E_MEMBER_EMAIL=e2e-member@example.com
E2E_MEMBER_PASSWORD=change_me_e2e_member
E2E_MEMBER_NAME=E2E Member
E2E_MEMBER_MUST_CHANGE_PASSWORD=true

# Playwright runtime vars (do not point to production by default)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
# E2E_MEMBER_NEW_PASSWORD=change_me_e2e_member_new
