generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum GameSessionSource {
  MANUAL
  ONLINE
}

enum OnlineLobbyStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  CLOSED
}

enum OnlineGamePlayerStatus {
  ACTIVE
  OUT
  LOST
}

enum OnlineGameStatus {
  IN_PROGRESS
  FINISHED
  CLOSED
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  emailVerified      Boolean  @default(false)
  image              String?
  role               Role     @default(MEMBER)
  banned             Boolean  @default(false)
  banReason          String?
  banExpires         DateTime?
  playerId           String?  @unique
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  player              Player?       @relation(fields: [playerId], references: [id], onDelete: SetNull)
  sessions            Session[]
  accounts            Account[]
  createdGameSessions GameSession[] @relation("GameSessionCreatedBy")
  ownedOnlineLobbies  OnlineLobby[] @relation("OnlineLobbyOwner")
  onlineLobbyPlayers  OnlineLobbyPlayer[]
  onlineGamePlayers   OnlineGamePlayer[]
  onlineEventActors   OnlineGameEvent[] @relation("OnlineGameEventActor")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?   @db.Text
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verification")
}

model Player {
  id          String   @id @default(cuid())
  displayName String
  notes       String?
  isActive    Boolean  @default(true)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user                User?
  groupMemberships    GroupMembership[]
  sessionParticipants SessionParticipant[]

  @@index([displayName])
  @@index([archivedAt])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships  GroupMembership[]
  gameSessions GameSession[]

  @@unique([name])
  @@index([archivedAt])
}

model GroupMembership {
  id        String   @id @default(cuid())
  groupId   String
  playerId  String
  createdAt DateTime @default(now())

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([groupId, playerId])
  @@index([playerId])
}

model GameSession {
  id              String   @id @default(cuid())
  groupId         String?
  title           String?
  playedAt        DateTime
  notes           String?
  source          GameSessionSource @default(MANUAL)
  archivedAt      DateTime?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  group         Group?               @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdByUser User?                @relation("GameSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  participants  SessionParticipant[]
  roundResults  RoundResult[]

  @@index([groupId])
  @@index([createdByUserId])
  @@index([playedAt])
  @@index([archivedAt])
}

model OnlineLobby {
  id          String            @id @default(cuid())
  code        String            @unique
  ownerUserId String
  status      OnlineLobbyStatus @default(WAITING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  closedAt    DateTime?
  emptySince  DateTime?

  owner  User                @relation("OnlineLobbyOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  players OnlineLobbyPlayer[]
  games   OnlineGame[]
  events  OnlineGameEvent[]

  @@index([status])
  @@index([ownerUserId])
  @@index([updatedAt])
}

model OnlineLobbyPlayer {
  id          String   @id @default(cuid())
  lobbyId     String
  userId      String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  isConnected Boolean  @default(true)
  seatIndex   Int
  readyState  Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  lobby OnlineLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([lobbyId, userId])
  @@unique([lobbyId, seatIndex])
  @@index([userId])
  @@index([leftAt])
}

model OnlineGame {
  id                    String            @id @default(cuid())
  lobbyId               String
  status                OnlineGameStatus @default(IN_PROGRESS)
  startedAt             DateTime          @default(now())
  finishedAt            DateTime?
  currentTurnPlayerId   String?
  moveNumber            Int               @default(0)
  drawPileCount         Int               @default(0)
  discardPileState      Json
  publicStateJson       Json
  privateStateJson      Json
  eliminationOrderJson  Json
  loserUserId           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  lobby   OnlineLobby       @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  players OnlineGamePlayer[]
  events  OnlineGameEvent[]

  @@unique([lobbyId])
  @@index([status])
  @@index([currentTurnPlayerId])
  @@index([loserUserId])
}

model OnlineGamePlayer {
  id               String                 @id @default(cuid())
  gameId           String
  userId           String
  seatIndex        Int
  status           OnlineGamePlayerStatus @default(ACTIVE)
  handCount        Int                    @default(0)
  faceDownCount    Int                    @default(3)
  faceUpCardsJson  Json
  privateStateJson Json
  placement        Int?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  game OnlineGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([gameId, userId])
  @@unique([gameId, seatIndex])
  @@index([userId])
  @@index([status])
  @@index([placement])
}

model OnlineGameEvent {
  id          String   @id @default(cuid())
  lobbyId     String
  gameId      String?
  actorUserId String?
  type        String
  payloadJson Json
  createdAt   DateTime @default(now())

  lobby OnlineLobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  game  OnlineGame? @relation(fields: [gameId], references: [id], onDelete: Cascade)
  actor User?       @relation("OnlineGameEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([lobbyId, createdAt])
  @@index([gameId, createdAt])
  @@index([actorUserId])
}

model SessionParticipant {
  id            String   @id @default(cuid())
  gameSessionId String
  playerId      String
  seatOrder     Int?
  createdAt     DateTime @default(now())

  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id], onDelete: Restrict)
  roundPlacements RoundPlacement[]

  @@unique([gameSessionId, playerId])
  @@unique([id, gameSessionId])
  @@index([playerId])
}

model RoundResult {
  id            String   @id @default(cuid())
  gameSessionId String
  sequenceNumber Int
  notes         String?
  archivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gameSession GameSession      @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  placements  RoundPlacement[]

  @@unique([gameSessionId, sequenceNumber])
  @@index([gameSessionId])
  @@index([archivedAt])
}

model RoundPlacement {
  id                   String   @id @default(cuid())
  roundResultId        String
  sessionParticipantId String
  position             Int
  createdAt            DateTime @default(now())

  roundResult        RoundResult        @relation(fields: [roundResultId], references: [id], onDelete: Cascade)
  sessionParticipant SessionParticipant @relation(fields: [sessionParticipantId], references: [id], onDelete: Restrict)

  @@unique([roundResultId, sessionParticipantId])
  @@unique([roundResultId, position])
  @@index([sessionParticipantId])
  @@index([position])
}
